# Browser-visible Supabase settings for signed Storage uploads.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_STORAGE_BUCKET=slideroom-uploads

# Server-only Vercel Function settings.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=slideroom-uploads
SLIDEROOM_STATE_ID=global-dev
SLIDEROOM_ROOM_TTL_HOURS=24
SLIDEROOM_MAX_UPLOAD_BYTES=524288000
# Signed uploads are enabled by default. Set both values to false only for local debugging.
VITE_ENABLE_SIGNED_UPLOADS=true
SLIDEROOM_ENABLE_SIGNED_UPLOADS=true
